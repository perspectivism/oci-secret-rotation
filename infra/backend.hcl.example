# Copy this file to backend.hcl, fill in your values, and run:
#   cd infra
#   terraform init -backend-config=backend.hcl
#
# backend.hcl is gitignored. Unlike an S3-compatible backend, this file
# contains no credentials — authentication is handled by ~/.oci/config.

# Name of the OCI Object Storage bucket created for Terraform remote state.
bucket = "<your-state-bucket-name>"

# OCI Object Storage namespace for your tenancy.
# Find it with: oci os ns get
namespace = "<your-namespace>"

# OCI region where the state bucket lives (e.g. us-ashburn-1).
region = "<your-region>"

# Path within the bucket for the Terraform state file.
key = "oci-secret-rotation/terraform.tfstate"
