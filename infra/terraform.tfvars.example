# Copy this file to terraform.tfvars and fill in your values.
# terraform.tfvars is gitignored — never commit it.
# Find OCIDs in the OCI Console or via: oci iam compartment list --all

# Your OCI tenancy OCID.
# Console: Administration → Tenancy Details → OCID
tenancy_ocid = "ocid1.tenancy.oc1..example"

# OCID of the IAM user whose API key is configured in ~/.oci/config.
# Console: Identity → Users → <your user> → OCID
user_ocid = "ocid1.user.oc1..example"

# OCI region identifier. Must match the region in ~/.oci/config.
# Examples: us-ashburn-1, eu-frankfurt-1, ap-sydney-1
region = "us-ashburn-1"

# OCID of the compartment in which all resources will be created.
# Create a dedicated compartment named secret-rotation for isolation.
# Console: Identity → Compartments → Create Compartment
compartment_ocid = "ocid1.compartment.oc1..example"

# Display name for the secret in OCI Vault.
secret_name = "secret-rotation-secret"

# Number of days between automatic rotations.
# 30 days is a reasonable default; adjust to match your security policy.
rotation_interval_days = 30

# OCID of the deployed rotation Function.
# Used in the vault secret's rotation_config so the Vault scheduler knows which
# function to invoke. This cannot be wired from the function module output because
# the vault secret and function have a circular dependency (vault needs the function
# OCID; the function app needs the secret OCID). Supplying it here as a static value
# breaks the cycle. The OCID is stable — it only changes if the function is destroyed
# and recreated, in which case update this value and re-run terraform apply.
# Console: Developer Services → Functions → Applications → <app> → <function> → OCID
# CLI: oci fn function list --application-id <app-ocid> --query 'data[0].id'
function_ocid = "ocid1.fnfunc.oc1..example"

# Email address or HTTPS URL for rotation event notifications via ONS.
# After terraform apply, OCI will send a subscription confirmation email —
# you must click the link before notifications are delivered.
# For HTTPS delivery (Slack, PagerDuty), set protocol in the logging module
# and provide the webhook URL here instead.
notification_endpoint = "you@example.com"
