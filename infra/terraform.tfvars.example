# Copy this file to terraform.tfvars and fill in your values.
# terraform.tfvars is gitignored — never commit it.
# Find OCIDs in the OCI Console or via: oci iam compartment list --all

# Your OCI tenancy OCID.
# Console: Administration → Tenancy Details → OCID
tenancy_ocid = "ocid1.tenancy.oc1..example"

# OCID of the IAM user whose API key is configured in ~/.oci/config.
# Console: Identity → Users → <your user> → OCID
user_ocid = "ocid1.user.oc1..example"

# OCI region identifier. Must match the region in ~/.oci/config.
# Examples: us-ashburn-1, eu-frankfurt-1, ap-sydney-1
region = "us-ashburn-1"

# OCID of the compartment in which all resources will be created.
# Create a dedicated compartment named secret-rotation-demo for isolation.
# Console: Identity → Compartments → Create Compartment
compartment_ocid = "ocid1.compartment.oc1..example"

# Display name for the demo secret in OCI Vault.
secret_name = "rotation-demo-secret"

# Number of days between automatic rotations.
# 30 days is a reasonable default for a demo; adjust to match your security policy.
rotation_interval_days = 30
